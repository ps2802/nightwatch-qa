    "audit:checkout": "playwright test --grep @checkout"
  },
  "keywords": [
    "nightwatch",
    "qa",
    "playwright"
  ],
  "author": "Nightwatch QA",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
